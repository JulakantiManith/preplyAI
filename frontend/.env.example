# API Configuration
VITE_API_URL=http://localhost:8000/api/v1

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# App Configuration
VITE_APP_NAME=Your App Name

# Custom Domain (optional)
# Set this to your production domain for auth redirect URLs.
# Leave empty for local development (defaults to window.location.origin).
# Example: interviewcoach.yourdomain.com
VITE_APP_DOMAIN=

# Auth Redirect URL Override (optional)
# Set this to explicitly override the auth callback URL used in email verification,
# password reset, and OTP flows. Takes precedence over VITE_APP_DOMAIN.
# Example: https://myapp.example.com/auth/callback
VITE_AUTH_REDIRECT_URL=

# Creator Attribution
VITE_CREATOR_NAME=Creator Name
VITE_GITHUB_URL=https://github.com/[User Name]
VITE_LINKEDIN_URL=https://www.linkedin.com/in/[User Name]
