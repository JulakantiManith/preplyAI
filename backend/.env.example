SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_SECRET=your-jwt-secret-key

# =============================================================================
# Domain Configuration
# =============================================================================

# Custom domain name (optional). Used to determine domain mode.
# Leave empty if not using a custom domain.
# Example: myapp.com
APP_DOMAIN=

# Frontend base URL. Must start with http:// or https://.
# Default: http://localhost:5173
# Example (production): https://myapp.com or https://my-app.vercel.app
FRONTEND_URL=http://localhost:5173

# Backend base URL. Must start with http:// or https://.
# Default: http://localhost:8000
# Example (production): https://api.myapp.com or https://my-app.onrender.com
BACKEND_URL=http://localhost:8000

# =============================================================================
# CORS Configuration
# =============================================================================

# Comma-separated list of allowed origins for CORS.
# Each entry must start with http:// or https://.
# FRONTEND_URL is automatically included — no need to duplicate it here.
# Default (when empty): http://localhost:5173
# Example: https://myapp.com,https://my-app.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=

# =============================================================================
# SMTP / Email Configuration (optional)
# =============================================================================
# All email features are disabled when required SMTP variables are missing.
# Required for email: SMTP_HOST, SMTP_PORT, SMTP_SENDER_EMAIL

# SMTP server hostname
# Example: smtp.sendgrid.net, smtp.mailgun.org
SMTP_HOST=

# SMTP server port (1-65535)
# Common values: 587 (STARTTLS), 465 (SSL), 25 (unencrypted)
# Default: 587
SMTP_PORT=587

# SMTP authentication username (optional if server allows anonymous)
SMTP_USERNAME=

# SMTP authentication password
SMTP_PASSWORD=

# Sender email address (max 254 characters). Required for email to be enabled.
# Example: noreply@myapp.com
SMTP_SENDER_EMAIL=

# Sender display name (max 78 characters)
# Example: My App
SMTP_SENDER_NAME=

# =============================================================================
# Email Deliverability Check (optional)
# =============================================================================
# When enabled, the application verifies SMTP connectivity at startup
# by performing an authenticated connection test (no email is sent).
# Default: false
EMAIL_DELIVERABILITY_CHECK_ENABLED=false
